# --- Postgres ---
POSTGRES_USER=datos
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=datos
DATABASE_URL=postgresql://datos:change-me-strong@postgres:5432/datos?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- API ---
NODE_ENV=production
PORT=4000
APP_DOMAIN=datos.nicoholas.dev
WEB_ORIGIN=https://datos.nicoholas.dev
TRUST_PROXY=1

# --- Secrets (generate with: openssl rand -base64 32) ---
JWT_SECRET=replace-with-32+bytes-random
COOKIE_SECRET=replace-with-32+bytes-random
CSRF_SECRET=replace-with-32+bytes-random
PASSWORD_PEPPER=replace-with-32+bytes-random
KEK_BASE64=replace-with-32bytes-base64-openssl-rand-base64-32
LOG_LEVEL=info

# --- Mantención ---
MAINT_HORIZON_YEARS=20
EVIDENCE_STORAGE_DIR=/var/lib/datos/evidencias
EVIDENCE_MAX_FILE_MB=25

# --- Seed (first boot only) ---
# Quote passwords if they contain spaces or !
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=CHANGE-THIS-AT-FIRST-LOGIN
SEED_SUPERADMIN_EMAIL_2=admin2@example.com
SEED_SUPERADMIN_PASSWORD_2=CHANGE-THIS-AT-FIRST-LOGIN

# --- IA búsqueda (NL → filtros JSON; nunca SQL) ---
# Modo simple: define AI_PROVIDER=nvidia|groq|openrouter + AI_MODEL=<model>
AI_PROVIDER=
AI_MODEL=
# Modo resiliente recomendado: orden + lista de modelos por provider
AI_PROVIDER_ORDER=nvidia,groq,openrouter
AI_MODELS_NVIDIA=z-ai/glm-5.1,deepseek-ai/deepseek-v4-pro,z-ai/glm4.7,minimaxai/minimax-m2.7,mistralai/mistral-medium-3.5-128b
AI_MODELS_GROQ=openai/gpt-oss-120b
AI_MODELS_OPENROUTER=z-ai/glm-4.5-air:free,openai/gpt-oss-120b:free
NVIDIA_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Web ---
NEXT_PUBLIC_API_URL=https://datos.nicoholas.dev

# --- Cloudflare (for Caddy DNS-01) ---
CLOUDFLARE_API_TOKEN=replace-with-scoped-token
ACME_EMAIL=admin@example.com

# --- Backups opcionales a S3/R2 (infra/backup.sh) ---
AGE_RECIPIENT=
S3_ENDPOINT=
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
