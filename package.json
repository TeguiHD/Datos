{
  "name": "datos-nicoholas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @datos/api prisma migrate dev",
    "db:seed": "pnpm --filter @datos/api db:seed",
    "import:excel": "pnpm --filter @datos/api import:excel"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "glob": "10.5.0",
      "lodash": "4.18.1",
      "multer": "2.1.1",
      "picomatch": "4.0.4"
    }
  }
}
